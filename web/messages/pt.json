    "tips": {
      "tip6": {
        "title": "Idade de Desmame",
        "content": "Desmame leitões entre 28 a 35 dias. Isso permite que cresçam mais fortes e se adaptem melhor à ração sólida."
      },
      "tip7": {
        "title": "Método de Separação Gradual",
        "content": "Reduza o estresse do desmame retirando a matriz da baia e deixando os leitões no ambiente familiar na primeira semana."
      },
      "tip8": {
        "title": "Prevenção de Correntes de Ar",
        "content": "Bloqueie ventos frios na creche instalando cortinas temporárias ou tábuas até a altura dos leitões (cerca de 50cm)."
      },
      "tip11": {
        "title": "Soro Caseiro de Reidratação",
        "content": "Forneça uma solução eletrolítica barata (5 colheres de açúcar, 1/2 de sal em 5 litros de água limpa) nos primeiros 3 dias de desmame."
      },
      "tip17": {
        "title": "Suplemento de Barro Vermelho",
        "content": "Coloque uma pá de terra vermelha limpa na baia de parto/creche. Os leitões comem para obter ferro e minerais naturais."
      },
      "tip20": {
        "title": "Cozimento de Subprodutos",
        "content": "Cozinhe subprodutos como cascas de mandioca ou batata para destruir toxinas naturais e melhorar a digestibilidade."
      },
      "tip21": {
        "title": "Fontes Locais de Proteína",
        "content": "Complemente a ração plantando forragens de alta proteína como Moringa, Azolla ou folhas de batata-doce na granja."
      },
      "tip22": {
        "title": "Restrição Alimentar na Gestação",
        "content": "Limite matrizes gestantes a 2-2,5 kg de ração por dia para evitar sobrepeso, o que causa partos difíceis."
      },
      "tip26": {
        "title": "Cozimento de Restos de Alimento",
        "content": "Ferva restos de comida por 30 minutos para destruir vírus como a Peste Suína Africana e Febre Aftosa."
      },
      "tip28": {
        "title": "Carvão para Digestão",
        "content": "Coloque pedaços de carvão vegetal nas baias de crescimento. Os suínos mastigam para ajudar a ligar toxinas estomacais."
      },
      "tip34": {
        "title": "Monta Controlada",
        "content": "Leve a fêmea em cio à baia do reprodutor para a cobertura, em vez de deixar o macho solto no rebanho."
      },
      "tip35": {
        "title": "Teste de Imobilidade",
        "content": "Teste o cio pressionando firmemente o lombo da fêmea; se ela ficar imóvel e eretar as orelhas, está pronta para a monta."
      },
      "tip39": {
        "title": "Proteção Contra Esmagamento",
        "content": "Instale barras de proteção (ferros ou paus a 20cm da parede e 20cm do chão) nas baias de parto."
      },
      "tip43": {
        "title": "Calendário de Coberturas",
        "content": "Marque a data da cobertura; a gestação dura cerca de 114 dias (3 meses, 3 semanas, 3 dias)."
      },
      "tip47": {
        "title": "Idade de Primeira Cobertura",
        "content": "Espere até que a marrã tenha pelo menos 8 meses e esteja no seu 2º ou 3º cio para garantir uma ninhada maior."
      },
      "tip48": {
        "title": "Isolamento de Novos Animais",
        "content": "Mantenha suínos recém-comprados em baia separada a pelo menos 20m de distância por 30 dias para checar doenças."
      },
      "tip49": {
        "title": "Pedilúvio DIY",
        "content": "Coloque uma bacia rasa com água e desinfetante (como cloro ou cal) no portão da granja."
      },
      "tip51": {
        "title": "Restrição de Visitantes",
        "content": "Não permita visitantes dentro das baias. Discuta negócios fora da área dos animais."
      },
      "tip55": {
        "title": "Controle Natural de Vermes",
        "content": "Sementes de mamão ou abóbora trituradas podem ajudar a reduzir vermes internos de forma barata."
      },
      "tip60": {
        "title": "Enterro Adequado",
        "content": "Enterre animais mortos a pelo menos 2m de profundidade, longe de fontes de água, e cubra com cal agrícola."
      },
      "tip61": {
        "title": "Espaço por Animal",
        "content": "Forneça pelo menos 1m² de espaço por animal em terminação para reduzir brigas e estresse."
      },
      "tip62": {
        "title": "Ventilação Natural",
        "content": "Projete galpões com laterais abertas para permitir a brisa e remover odores."
      },
      "tip75": {
        "title": "Compostagem DIY",
        "content": "Empilhe o esterco em local seco, cubra com palha e vire semanalmente para fazer adubo."
      },
      "tip76": {
        "title": "Biodigestor de Saco",
        "content": "Instale um biodigestor plástico tubular de baixo custo para tratar dejetos e produzir gás de cozinha grátis."
      },
      "tip92": {
        "title": "Idade de Castração",
        "content": "Castre os machos antes dos 7 dias de vida. O procedimento é rápido, cura logo e causa dor mínima."
      },
      "tip94": {
        "title": "Registros em Caderno",
        "content": "Mantenha um caderno simples no galpão para anotar datas de cobertura, parto e tratamentos."
      }
    }
  },
