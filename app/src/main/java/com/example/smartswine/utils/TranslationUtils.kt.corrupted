object Translator {
    private val translations = mapOf(
        "en" to getEnTranslations() + getExtrasEn(),
        "fr" to getFrTranslations() + getExtrasFr(),
        "zh" to getZhTranslations() + getExtrasZh(),
        "es" to getEsTranslations() + getExtrasEs(),
        "tl" to getTlTranslations() + getExtrasTl(),
