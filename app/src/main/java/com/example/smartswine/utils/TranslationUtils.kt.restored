        "last_updated" to "อัปเดตล่าสุด: %s",
        "edit_profile_title" to "แก้ไขโปรไฟล์",
        "save_changes" to "บันทึกการเปลี่ยนแปลง",
        "login_credentials" to "ข้อมูลการเข้าสู่ระบบ",
