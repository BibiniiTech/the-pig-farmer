enum class AppLanguage(val code: String, val displayName: String, val flag: String) {
    ENGLISH("en", "English", "🇺🇸"),
    FRENCH("fr", "Français", "🇫🇷"),
    CHINESE("zh", "中文", "🇨🇳"),
    SPANISH("es", "Español", "🇪🇸"),
    FILIPINO("tl", "Filipino", "🇵🇭"),
    VIETNAMESE("vi", "Tiếng Việt", "🇻🇳"),
    THAI("th", "ไทย", "🇹🇭"),
    PORTUGUESE("pt", "Português", "🇵🇹"),
    HINDI("hi", "हिन्दी", "🇮🇳");

    fun toLocale(): java.util.Locale = java.util.Locale.forLanguageTag(code)
}

object Translator {
    private val translations = mapOf(
        "en" to getEnTranslations() + getExtrasEn(),
        "fr" to getFrTranslations() + getExtrasFr(),
        "zh" to getZhTranslations() + getExtrasZh(),
        "es" to getEsTranslations() + getExtrasEs(),
        "tl" to getTlTranslations() + getExtrasTl(),
        "vi" to getViTranslations() + getExtrasVi(),
        "th" to getThTranslations() + getExtrasTh(),
        "pt" to getPtTranslations() + getExtrasPt(),
        "hi" to getHiTranslations() + getExtrasHi()
    )

    fun getString(key: String, languageCode: String, vararg args: Any): String {
        val template = translations[languageCode]?.get(key) ?: translations["en"]?.get(key) ?: key
        return try {
            String.format(java.util.Locale.forLanguageTag(languageCode), template, *args)
        } catch (_: Exception) {
            template
        }
    }

