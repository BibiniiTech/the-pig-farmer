        "confirm_new_password" to "ยืนยันรหัสผ่านใหม่",
        "tos_acceptance_title" to "1. การยอมรับข้อกำหนด",
        "tos_acceptance_content" to "โดยการเข้าถึงและใช้งานแอป SmartSwine คุณตกลงที่จะผูกพันตามข้อกำหนดการให้บริการเหล่านี้ หากคุณไม่ตกลง โปรดอย่าใช้บริการ",
        "tos_description_title" to "2. คำอธิบายบริการ",
        "tos_description_content" to "\"SmartSwine\" จัดหาเครื่องมือจัดการฟาร์มรวมถึง:\n• การติดตามฝูงสัตว์และข้อมูลสุขภาพ\n• การบันทึกข้อมูลการเงิน\n• การจัดการทรัพยากรบุคคล\n• คำแนะนำการวินิจฉัยโดย AI\n• ข้อมูลการเข้าถึงตลาด",
        "tos_data_privacy_title" to "3. ความเป็นส่วนตัวของข้อมูลและการสำรองข้อมูลบนคลาวด์",
        "tos_data_privacy_content" to "คุณยังคงเป็นเจ้าของข้อมูลที่คุณกรอก ข้อมูลของคุณจะถูกเก็บไว้อย่างปลอดภัยโดยใช้ Google Firebase แม้ว่าเราจะพยายามปกป้องข้อมูล แต่เราไม่สามารถรับประกันความปลอดภัยที่สมบูรณ์ได้ โดยการเปิดใช้ระบบคลาวด์ คุณยินยอมให้จัดเก็บและซิงค์ข้อมูล",
        "tos_no_medical_title" to "4. ไม่มีคำแนะนำทางการแพทย์หรือทางสัตวแพทย์",
        "tos_no_medical_content" to "ฟีเจอร์ AI และเครื่องคำนวณมีไว้เพื่อการศึกษาเท่านั้น ผลลัพธ์ที่ได้ไม่สามารถทดแทนคำแนะนำจากสัตวแพทย์มืออาชีพได้ ผู้ใช้ตกลงที่จะปรึกษาสัตวแพทย์ก่อนตัดสินใจทางการแพทย์ใดๆ",
        "tos_user_resp_title" to "5. ความรับผิดชอบของผู้ใช้",
        "tos_user_resp_content" to "ผู้ใช้มีหน้าที่รักษาความลับของข้อมูลบัญชี คุณต้องรับผิดชอบต่อกิจกรรมทั้งหมดที่เกิดขึ้นภายใต้บัญชีของคุณ",
        "tos_prohibited_title" to "6. พฤติกรรมที่ต้องห้าม",
        "tos_prohibited_content" to "ผู้ใช้ตกลงที่จะไม่: ใช้แอปเพื่อวัตถุประสงค์ที่ผิดกฎหมาย พยายามเจาะระบบแอป หรือกรอกข้อมูลการเงินที่เป็นเท็จ",
        "tos_availability_title" to "7. ความพร้อมในการให้บริการ",
        "tos_availability_content" to "เราพยายามให้บริการได้ 99% แต่ไม่รับประกันการเข้าถึงที่ต่อเนื่อง การสำรองข้อมูลจัดทำขึ้นเพื่อความสะดวก ผู้ใช้ควรเก็บข้อมูลของตนเองไว้ด้วย",
        "tos_liability_title" to "8. การจำกัดความรับผิด",
        "tos_liability_content" to "แอปจัดหาให้ \"ตามสภาพ\" เท่าที่กฎหมายอนุญาต นักพัฒนาจะไม่รับผิดชอบต่อความเสียหายใดๆ ที่เกิดจากการใช้บริการ",
        "tos_financial_data_title" to "9. ข้อมูลการเงิน",
        "tos_financial_data_content" to "โมดูลการเงินเป็นเครื่องมือติดตามและไม่ใช่คำแนะนำทางบัญชีมืออาชีพ ผู้ใช้ควรส่งออกข้อมูลเพื่อให้นักบัญชีตรวจสอบ",
        "tos_changes_title" to "10. การเปลี่ยนแปลงข้อกำหนด",
        "tos_changes_content" to "เราขอสงวนสิทธิ์ในการแก้ไขข้อกำหนดเหล่านี้ การใช้งานอย่างต่อเนื่องหมายถึงการยอมรับข้อกำหนดใหม่",
        "tos_contact_title" to "11. ข้อมูลการติดต่อ",
        "tos_contact_content" to "สำหรับการสนับสนุนหรือคำถามทางกฎหมาย โปรดติดต่อผู้พัฒนาผ่านการตั้งค่าโปรไฟล์ของแอป",
        "contact_support" to "ติดต่อฝ่ายสนับสนุน: %s",
        "quote_1" to "เกษตรกรรมเป็นการจ้างงานที่ดีต่อสุขภาพ มีประโยชน์ และสูงส่งที่สุดของมนุษย์ - จอร์จ วอชิงตัน",
        "quote_2" to "เกษตรกรเป็นคนคนเดียวในเศรษฐกิจของเราที่ซื้อทุกอย่างในราคาปลีก ขายทุกอย่างในราคาส่ง และจ่ายค่าขนส่งทั้งสองทาง - จอห์น เอฟ. เคนเนดี",
        "quote_3" to "การทำฟาร์มคืออาชีพแห่งความหวัง - ไบรอัน เบรตต์",
        "quote_4" to "เป้าหมายสูงสุดของการทำฟาร์มไม่ใช่การปลูกพืช แต่เป็นการบ่มเพาะและความสมบูรณ์แบบของมนุษย์ - มาซาโนบุ ฟุกุโอกะ",
        "quote_5" to "งานหนักช่วยส่องสว่างตัวตนของผู้คน: บางคนม้วนแขนเสื้อขึ้น บางคนทำจมูกย่น และบางคนไม่ปรากฏตัวเลย - แซม อีวิง",
        "quote_6" to "ความพากเพียรมีความสำคัญต่ออุปนิสัยของมนุษย์ เหมือนกับคาร์บอนที่มีต่อเหล็กกล้า - นโปเลียน ฮิลล์",
        "quote_7" to "ความสำเร็จไม่ใช่จุดสิ้นสุด ความล้มเหลวไม่ใช่เรื่องคอขาดบาดตาย: ความกล้าที่จะเดินหน้าต่อไปต่างหากที่สำคัญ - วินสตัน เชอร์ชิลล์",
        "quote_8" to "ที่เดียวที่ความสำเร็จมาก่อนการทำงานคือในพจนานุกรม - วิดัล แซสซูน",
        "quote_9" to "อย่าตัดสินแต่ละวันจากพืชผลที่คุณเก็บเกี่ยว แต่ให้ตัดสินจากเมล็ดพันธุ์ที่คุณหว่านลงไป - โรเบิร์ต หลุยส์ สตีเวนสัน",
        "quote_10" to "วิธีที่ดีที่สุดในการทำนายอนาคตของคุณคือการสร้างมันขึ้นมา - อับราฮัม ลินคอล์น",
        "quote_11" to "งานหนักชนะพรสวรรค์ เมื่อพรสวรรค์ไม่ทำงานหนัก - ทิม น็อตเก้",
        "quote_12" to "การทำฟาร์มดูเหมือนจะง่ายมากเมื่อคันไถของคุณคือดินสอ และคุณอยู่ห่างจากทุ่งข้าวโพดหนึ่งพันไมล์ - ดไวต์ ดี. ไอเซนฮาวร์",
        "quote_13" to "สายตาของเจ้าของทำให้หมูอ้วน - สุภาษิต",
        "quote_14" to "สิ่งที่ยิ่งใหญ่สำเร็จได้ด้วยสิ่งเล็กน้อยหลายอย่างที่นำมารวมกัน - วินเซนต์ แวน โก๊ะ",
        "quote_15" to "รากฐานของทุกรัฐคือการศึกษาของเยาวชน - ไดโอจินีส",
        "quote_16" to "ชีวิตในฟาร์มคือโรงเรียนแห่งความอดทน คุณไม่สามารถเร่งพืชผลหรือสร้างวัวในสองวันได้ - อองรี อาลัน",
        "quote_17" to "การทำฟาร์มไม่ใช่แค่เรื่องงาน แต่มันคือวิถีชีวิต - ไม่ระบุชื่อ",
        "quote_18" to "เป้าหมายไม่ใช่การเก่งกว่าคนอื่น แต่เป็นการเก่งกว่าตัวคุณในอดีต - ดาไล ลามะ",
        "quote_19" to "ความยั่งยืนคือเรื่องของอนาคตของลูกหลานเรา - ไม่ระบุชื่อ",
        "quote_20" to "หน้าที่แรกของเกษตรกรคือการทำให้ดินดีขึ้นกว่าตอนที่เขาพบมัน - ไม่ระบุชื่อ",
        "quote_21" to "ทำงานหนักอย่างเงียบเชียบ และปล่อยให้ความสำเร็จส่งเสียงแทนคุณ - แฟรงก์ โอเชียน",
        "quote_22" to "ความพากเพียรสามารถเปลี่ยนความล้มเหลวให้เป็นความสำเร็จที่ยิ่งใหญ่ได้ - แมตต์ บิออนดิ",
        "quote_23" to "งานของเกษตรกรไม่มีวันสิ้นสุด แต่ผลตอบแทนนั้นเป็นนิรันดร์ - ไม่ระบุชื่อ",
        "quote_24" to "ทุกวันคือโอกาสใหม่ในการเติบโต - ไม่ระบุชื่อ",
        "quote_25" to "การเติบโตไม่ได้เกิดขึ้นโดยบังเอิญ แต่มันคือผลลัพธ์ของพลังที่ทำงานร่วมกัน - เจมส์ แคช เพนนีย์",
        "quote_26" to "ชีวิตที่เรียบง่ายคือรางวัลในตัวมันเอง - ไม่ระบุชื่อ",
        "quote_27" to "เกษตรกรคือกระดูกสันหลังของโลก - ไม่ระบุชื่อ",
        "quote_28" to "ทุ่งนาจะดีได้ก็ต่อเมื่อมีคนที่คอยดูแลมันเป็นอย่างดี - ไม่ระบุชื่อ",
        "quote_29" to "สำหรับเกษตรกร ทุกเมล็ดพันธุ์คือคำสัญญา - ไม่ระบุชื่อ",
        "quote_30" to "ศรัทธาคือวิกที่สัมผัสได้ถึงแสงสว่างในขณะที่รุ่งอรุณยังมืดมิด - รพินทรนาถ ฐากูร",
        "quote_31" to "ความสำเร็จมักมาหาผู้ที่ยุ่งเกินกว่าจะมองหาตัวมัน - เฮนรี เดวิด โธโร",
        "quote_32" to "ไม่มีทางลัดไปยังสถานที่ใดก็ตามที่คุ้มค่าแก่การไป - เบเวอร์ลี ซิลส์",
        "quote_33" to "เชื่อว่าคุณทำได้ และคุณก็มาได้ครึ่งทางแล้ว - ธีโอดอร์ รูสเวลต์",
        "quote_34" to "หัวใจของคุณก็เหมือนสวน คุณสามารถปลูกดอกไม้หรือจะปลูกวัชพืชก็ได้ - ไม่ระบุชื่อ",
        "quote_35" to "การค้นพบเกษตรกรรมเป็นก้าวแรกที่ยิ่งใหญ่สู่ชีวิตที่มีอารยธรรม - อาร์เธอร์ คีธ",
        "quote_36" to "ผู้เพาะปลูกบนผืนดินคือพลเมืองที่มีค่าที่สุด - โธมัส เจฟเฟอร์สัน",
        "quote_37" to "เกษตรกรต้องเป็นคนมองโลกในแง่ดี ไม่อย่างนั้นเขาคงเลิกเป็นเกษตรกรไปแล้ว - วิล โรเจอร์ส",
        "quote_38" to "มีเพียงเกษตรกรที่ปลูกเมล็ดพันธุ์อย่างซื่อสัตย์ในฤดูใบไม้ผลิเท่านั้นที่จะได้เก็บเกี่ยวผลผลิตในฤดูใบไม้ร่วง - บี.ซี. ฟอร์บส์",
        "quote_39" to "ไม่มีเผ่าพันธุ์ใดเจริญรุ่งเรืองได้จนกว่าจะเรียนรู้ว่าการทำนามีเกียรติพอๆ กับการเขียนบทกวี - บุ๊คเกอร์ ที. วอชิงตัน",
        "quote_40" to "หากคุณจี้แผ่นดินด้วยจอบ เธอจะหัวเราะออกมาเป็นผลผลิต - ดักลาส เจอร์โรลด์",
        "quote_41" to "เกษตรกรรมไม่เพียงแต่ให้ความมั่งคั่งแก่ชาติ แต่ยังเป็นความมั่งคั่งเพียงอย่างเดียวที่ชาติเรียกได้ว่าเป็นของตนเอง - ซามูเอล จอห์นสัน",
        "quote_42" to "ศิลปะแห่งเกษตรกรรมคือศิลปะแห่งการเป็นหุ้นส่วนกับพระเจ้า - ไม่ระบุชื่อ",
        "quote_43" to "การเป็นเกษตรกรหมายความว่าคุณต้องมีความอดทนอย่างมาก - ไม่ระบุชื่อ",
        "quote_44" to "ทุกสิ่งที่ทำให้เราช้าลงและบังคับให้เราอดทน ทุกสิ่งที่ทำให้เรากลับสู่รอบวงจรที่เชื่องช้าของธรรมชาติ คือตัวช่วย - เมย์ ซาร์ตัน",
        "quote_45" to "เกษตรกรคือนักมายากลที่เสกเงินขึ้นมาจากโคลนตม - อมิต กาลันตรี",
        "quote_46" to "ดินคือครึ่งหนึ่งของธรรมชาติที่ซ่อนอยู่ - ไม่ระบุชื่อ",
        "quote_47" to "การไถคือรากฐานของเกษตรกรรม - ไม่ระบุชื่อ",
        "quote_48" to "ธรรมชาติไม่เคยรีบร้อน แต่ทุกสิ่งก็สำเร็จลุล่วง - เล่าจื๊อ",
        "quote_49" to "ผู้ที่มีที่ดินย่อมมีทองคำ - สุภาษิตแอฟริกัน",
        "quote_50" to "ดูแลที่ดิน แล้วที่ดินจะดูแลคุณ - ไม่ระบุชื่อ",
        "quote_51" to "เกษตรกรรายย่อยคือวีรบุรุษในระบบอาหารของเรา - ไม่ระบุชื่อ",
        "quote_52" to "ความพากเพียรคือฝาแฝดของความยอดเยี่ยม อย่างหนึ่งคือเรื่องของคุณภาพ อีกอย่างหนึ่งคือเรื่องของเวลา - มาราเบล มอร์แกน",
        "quote_53" to "งานหนักคือสูตรสำเร็จของความสำเร็จ - ไม่ระบุชื่อ",
        "quote_54" to "หยาดเหงื่อของเกษตรกรคือน้ำฝนสำหรับพืชผล - ไม่ระบุชื่อ",
        "quote_55" to "ยิ่งคุณทำงานหนักเพื่อบางสิ่งมากเท่าไหร่ คุณจะยิ่งรู้สึกดีมากขึ้นเท่านั้นเมื่อคุณทำสำเร็จ - ไม่ระบุชื่อ",
        "quote_56" to "ความสำเร็จคือผลรวมของความพยายามเล็กๆ ที่ทำซ้ำแล้วซ้ำเล่าวันแล้ววันเล่า - โรเบิร์ต คอลลิเยอร์",
        "quote_57" to "ฝันให้ใหญ่ ทำงานหนัก และมีสมาธิ - ไม่ระบุชื่อ",
        "quote_58" to "ความท้าทายคือสิ่งที่ทำให้ชีวิตน่าสนใจ และการเอาชนะมันคือสิ่งที่ทำให้ชีวิตมีความหมาย - โจชัว เจ. มารีน",
        "quote_59" to "อย่ารอโอกาส แต่จงสร้างมันขึ้นมา - ไม่ระบุชื่อ",
        "quote_60" to "ความลับของการก้าวไปข้างหน้าคือการเริ่มลงมือทำ - มาร์ก ทเวน",
        "quote_61" to "คุณภาพไม่ใช่การกระทำ แต่มันคือนิสัย - อริสโตเติล",
        "quote_62" to "ฉันพบว่ายิ่งฉันทำงานหนักเท่าไหร่ ฉันก็ยิ่งดูเหมือนจะมีโชคมากขึ้นเท่านั้น - โธมัส เจฟเฟอร์สัน",
        "quote_63" to "ความเข้มแข็งและการเติบโตมาจากการพยายามและการต่อสู้ที่ต่อเนื่องเท่านั้น - นโปเลียน ฮิลล์",
        "quote_64" to "ความกล้าหาญไม่ใช่การมีกำลังเพื่อที่จะไปต่อ แต่มันคือการไปต่อในเวลาที่คุณไม่มีกำลังเหลือแล้ว - ธีโอดอร์ รูสเวลต์",
        "quote_65" to "ถนนสู่ความสำเร็จอยู่ระหว่างการก่อสร้างเสมอ - ลิลลี ทอมลิน",
        "quote_66" to "ความล้มเหลวคือเครื่องปรุงที่ทำให้ความสำเร็จมีรสชาติ - ทรูแมน คาโพตี",
        "quote_67" to "อย่าอายในความล้มเหลว จงเรียนรู้จากมันและเริ่มใหม่ - ริชาร์ด แบรนสัน",
        "quote_68" to "ช่วงเวลาที่ยากลำบากไม่ได้สร้างวีรบุรุษ แต่เป็นช่วงเวลาที่ยากลำบากที่ 'วีรบุรุษ' ในตัวเราจะถูกเปิดเผย - บ็อบ ไรลีย์",
        "quote_69" to "ตัวตนคือความสามารถในการทำตามความตั้งใจที่ดีได้นานหลังจากที่ความตื่นเต้นในขณะนั้นผ่านพ้นไปแล้ว - คาเวตต์ โรเบิร์ต",
        "quote_70" to "ผลผลิตของคุณจะมาถึงหากคุณไม่ยอมแพ้ - ไม่ระบุชื่อ",
        "farmer" to "เกษตรกร",
        "maize" to "ข้าวโพด",
        "maize_bran" to "รำข้าวโพด",
        "soybean_meal" to "กากถั่วเหลือง",
