rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Checks if the user is a registered staff member for this manager
    function isStaffOf(managerId) {
      return isAuthenticated() &&
             'email' in request.auth.token &&
             exists(/databases/$(database)/documents/staff_registry/$(request.auth.token.email.lower())) &&
             get(/databases/$(database)/documents/staff_registry/$(request.auth.token.email.lower())).data.managerUid == managerId;
    }

    // Checks if the user is an admin
    function isAdmin() {
      return isAuthenticated() &&
             (
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('admin', false) == true) ||
               ('email' in request.auth.token && request.auth.token.email_verified == true && request.auth.token.email == 'bibiniitech@gmail.com')
             );
    }

    // --- Rules ---

    // Global Feed Ingredients: Read for everyone, Write for Admins
    match /global_feed_ingredients/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Market Providers: Read for everyone, Write for Admins
    match /market_providers/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Market Suggestions:
    // - Users can create suggestions.
    // - Users can read their own suggestions.
    // - Admins can read, update, and delete all suggestions.
    match /market_suggestions/{docId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Training Videos: Read for everyone, Write for Admins
    match /training_videos/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Staff Registry: Read for the user themselves, Write for the manager
    match /staff_registry/{email} {
      allow read: if isAuthenticated() && (('email' in request.auth.token && request.auth.token.email.lower() == email.lower()) || isOwner(get(/databases/$(database)/documents/staff_registry/$(email)).data.managerUid));
      allow write: if isAuthenticated(); // Broad for now, handled by app logic, but can be tightened
    }

    // User Data and Subcollections
    match /users/{userId} {
      // Allow read for owner and their staff
      allow read: if isOwner(userId) || isStaffOf(userId);
      // Allow create only for owner, preventing client-side creation of admin/premium profiles
      allow create: if isOwner(userId) && 
                    (!('admin' in request.resource.data) || request.resource.data.admin == false) &&
                    (!('isPremium' in request.resource.data) || request.resource.data.isPremium == false) &&
                    (!('isKofisPerson' in request.resource.data) || request.resource.data.isKofisPerson == false);

      // Allow update only for owner, preventing modifications to admin/isKofisPerson, and upgrades to isPremium
      allow update: if isOwner(userId) && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['admin', 'isKofisPerson']) &&
                    (request.resource.data.isPremium == false || resource.data.isPremium == request.resource.data.isPremium);

      allow delete: if isOwner(userId);

      // Subcollections (Pigs, Financials, Tasks, etc.)
      match /{allSubcollections=**} {
        // Owner has full access
        allow read, write: if isOwner(userId);

        // Staff has read access to everything
        allow read: if isStaffOf(userId);
      }

      // Specific Write access for Staff on operational collections
      match /pigs/{pigId} {
        allow write: if isStaffOf(userId);
        match /health_records/{recordId} {
          allow write: if isStaffOf(userId);
        }
      }
      match /archived_pigs/{pigId} {
        allow write: if isStaffOf(userId);
        match /health_records/{recordId} {
          allow write: if isStaffOf(userId);
        }
      }
      match /tasks/{taskId} {
        allow write: if isStaffOf(userId);
      }
      match /feed_inventory/{itemId} {
        allow write: if isStaffOf(userId);
      }
      match /feed_inventory_transactions/{txId} {
        allow write: if isStaffOf(userId);
      }
      match /feed_transactions/{txId} {
        allow write: if isStaffOf(userId);
      }
    }
  }
}
